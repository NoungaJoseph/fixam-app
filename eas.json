{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.usefixam.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.usefixam.com",
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx4096m",
        "SENTRY_ORG": "fixam",
        "SENTRY_PROJECT": "react-native",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "developmentClient": false,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.usefixam.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.usefixam.com",
        "SENTRY_ORG": "fixam",
        "SENTRY_PROJECT": "react-native",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
